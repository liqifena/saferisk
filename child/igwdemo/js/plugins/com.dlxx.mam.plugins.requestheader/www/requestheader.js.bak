cordova.define("org.apache.cordova.requestheader", function(require,exports,module){

    var exec = require('cordova/exec');

    module.exports = {	
		/** 
		 * 一共5个参数 
		   第一个 :成功回调 
		   第二个 :失败回调 
		   第三个 :将要调用的类的配置名字
		   第四个 :调用的方法名(一个类里可能有多个方法 靠这个参数区分) 
		   第五个 :传递的参数  以json的格式 
		 */  
        getJSON: function(appcode,params,appservercode,successCallBack,errCallBack) {
			 alert("plugins → getJSON");
            exec(successCallBack, errCallBack, "RequestHeader", "getJSON", [appcode,params,appservercode]);
        },		
		get: function(appcode,params,appservercode,successCallBack,errCallBack) {
            exec(successCallBack, errCallBack, "RequestHeader", "get", [appcode,params,appservercode]);
        },
			

		post:function(appcode,params,appservercode,successCallBack,errCallBack) {
            exec(successCallBack, errCallBack, "RequestHeader", "post", [appcode,params,appservercode]);
        },
		postJSON:function(appcode,params,appservercode,successCallBack,errCallBack) {
			exec(successCallBack, errCallBack, "RequestHeader", "postJSON", [appcode,params,appservercode]);
        },getJSON: function(appcode,params,appservercode,successCallBack,errCallBack) {
            exec(successCallBack, errCallBack, "RequestHeader", "getJSON", [appcode,params,appservercode]);
        },



		getJSONISCP: function(appcode,params,appservercode,successCallBack,errCallBack) {
            exec(successCallBack, errCallBack, "accessGatewayWithISCP", "getJSON", [appcode,params,appservercode]);
        },
		getISCP: function(appcode,params,appservercode,successCallBack,errCallBack) {
            exec(successCallBack, errCallBack, "accessGatewayWithISCP", "get", [appcode,params,appservercode]);
        },

		
		postISCP:function(appcode,params,appservercode,successCallBack,errCallBack) {
            exec(successCallBack, errCallBack, "accessGatewayWithISCP", "post", [appcode,params,appservercode]);
        },
		postJSONISCP:function(appcode,params,appservercode,successCallBack,errCallBack) {
			exec(successCallBack, errCallBack, "accessGatewayWithISCP", "postJSON", [appcode,params,appservercode]);
        },






		init:function(successCallBack,errCallBack) {
			exec(successCallBack, errCallBack, "ISCPRaw", "init", []);
        },
		  //安全交互网关的ip端口,user,appId由安全接入网关服务提供商（联研院)提供
		 connectIscpServer:function(sagIP,sagPort,user,appId,successCallBack,errCallBack) {
			 exec(successCallBack, errCallBack, "ISCPRaw", "connectIscpServer", [sigIP,sigPort,user,appId]);
		},
		 //业务服务的ip端口
		 getLocalPort:function(ip,port,successCallBack,errCallBack) {
		  exec(successCallBack, errCallBack, "ISCPRaw", "getLocalPort", [ip,port]);
		},
		getStatus:function(successCallBack,errCallBack) {
			exec(successCallBack, errCallBack, "ISCPRaw", "getStatus", []);
        },
		closeISCP:function(successCallBack,errCallBack) {
			exec(successCallBack, errCallBack, "ISCPRaw", "closeISCP", []);
        }


    };

});
//fengxf added end


