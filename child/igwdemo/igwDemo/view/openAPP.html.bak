<input type='button' onclick='shareToWX()' value='分享-微信'></input><br><br>

<input type='button' onclick='shareToWXCircle()' value='分享-微信-朋友圈'></input><br><br>

<input type='button' onclick='jsz()' value='分享-i国网'></input><br><br>

