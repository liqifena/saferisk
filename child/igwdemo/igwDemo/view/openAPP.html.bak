<!doctype html>
<html lang="en">
 <head>
  <meta charset="UTF-8">
  <meta name="Generator" content="EditPlus®">
  <meta name="Author" content="">
  <meta name="Keywords" content="">
  <meta name="Description" content="">
  <title>Document</title>
   <script type="text/javascript" charset="utf-8" src="../cordova.js"></script>   
   <script src="../js/jquery-1.9.1.min.js"></script>
		<script src="../js/public.js"></script>
<script type="text/javascript">
	var ready = false;
    function onLoad(){
        document.addEventListener("deviceready", onDeviceReady, false);
    	console.log("onLoad()");
    }
	function onDeviceReady() {
    	console.log("onDeviceReady()-->start");
    	ready = true;
		console.log("onDeviceReady()--end");
    }

	function openAPP()
	{
		
		var IOSAPP = document.getElementById("appurl").value;
		
		if(IOSAPP =="")
		{
			IOSAPP="sgcchnlbs://order.start?workOrder=10011002";
			openOtherApp(IOSAPP);
		}else if(IOSAPP!="")
		{
			openOtherApp(IOSAPP);
		}else
		{
			alert("请输入正确的值！");
		}
	}
	/**
		打开第三方 百度地图 app 
		次方法只支持IOS   安卓使用 H5 标签  见下文 <p>H5打开定制地图app 【android】</p>
		参数说明：
		   url			第三方地图app schemes 信息  IOSAPP="sgcchnlbs://order.start?workOrder=10011002";
		   onSuccess	成功回调
		   onError		失败回调

	**/
	function openOtherApp(IOSAPP) {
		alert(IOSAPP);
		if(!ready){
    		console.log("Cordova is not ready,return");
    		return;
    	}
		var devicePlatform = device.platform;
		console.log(" executeOpenFile() ,devicePlatform:" + devicePlatform);

		if("iOS" == devicePlatform){
	
			navigator.openURL.openInSafari(IOSAPP,successCallback,errorCallback);

		}else if("Android" == devicePlatform){
			alert('【android】 设备直接使用标签打开');
		}else{
			console.log("invaiate platform");
		}
        
    }

    function successCallback(msg) {
            console.log('successCallback:' + JSON.stringify(msg));
    }

    function errorCallback(msg) {
            console.log('errorCallback:' + JSON.stringify(msg));
    }

	/**
		分享 微信 
		参数说明：
		   addr:点击分享而跳转的地址		http://www.autohome.com.cn/	   		   
		   share_title: 分享的标题			汽车之家
		   share_description: 分享的描述	分享功能开发测试	
		   icon: 应用的图标					device.png

	**/
    function shareToWX() {
			mam.navigator.share.shareToWX(sucCallback,errCallback,"https://mam1.ft-power.com.cn:10030/html8/1.mp4","视频1——标题","视频-描述","111.png");
    }
	/**
		分享 微信 朋友圈
		参数说明：
		   addr:点击分享而跳转的地址		http://www.autohome.com.cn/	   		   
		   share_title: 分享的标题			汽车之家
		   share_description: 分享的描述	分享功能开发测试	
		   icon: 应用的图标					device.png

	**/
    function shareToWXCircle() {
            mam.navigator.share.shareToWXCircle(sucCallback,errCallback,"https://mam1.ft-power.com.cn:10030/html8/4.mp4","视频1——标题","视频-描述","device.png");	
    }

	function sucCallback(v){
	    alert("sucCallback" + JSON.stringify(v));
	}
	function errCallback(v){
	    alert("errCallback" + JSON.stringify(v));	
	}




	function jsz()){
	    alert("建设中" );	
	}


</script>


 </head>

<body onload="onLoad();">

输入URL：<input type="text" id="appurl" name="appurl" />

 <p></p>在Safari中打开链接测试【IOS】<p>
 <input type="button" onclick="openAPP()" value='打开第三方app'></a>



