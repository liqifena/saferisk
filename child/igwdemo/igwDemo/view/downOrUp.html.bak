/**
	文件 下载 
	appCode			应用编码		填写应用编码，保存文件至应用相对路径：
	appServerCode	应用服务编码	使用应用服务编码进行下载

	urlType			URL类型		20200618 目前先填 0 使用白名单下载
								0 白名单downLoadUrl必填
								1 应用服务编码	（此处填 1 	则appServerCode必填）
	downLoadUrl		下载URL			文件下载URL  可为互联网URL 和 白名单URL
	saveUrl			本地保存url		保存应用相对路径 如：设置 /PDF   对应实际路径 SGCCINTSYS/PDF/1_pdf_101M_文档.pdf
	fileName		文件名称		保存本地文件名称 重命名文件 【文件名称必须带后缀】 1_doc_22b_文档.doc
	appName			应用名称		应用名称		
----fileSize		文件大小		固定值 作废 传10000----
----fileStatus		文件状态		固定值 作废 传 0 文件状态：0 允许打开  1 不允许打开----
	fileCode		文件编码		文件编码	内容自定义、唯一  用于批量删除
**/

function fileDownload(appCode,downLoadUrl,saveUrl,fileName,fileCode)
{
	
	var appServerCode ='download';
	var urlType  = 0;
	var fileSize   ='10000';
	var fileStatus  ='0';	

	

	console.log(
	" 应用编码= "+appCode+
	"\r\n 应用服务编码= "+ appServerCode +
	"\r\n 下载类型= "+ urlType +
	"\r\n 下载URL= " + downLoadUrl+
	"\r\n 保存url= " + saveUrl +
	"\r\n 文件名称= " + fileName +
	"\r\n 应用名称= " + appName +
	"\r\n 文件大小= " + fileSize +
	"\r\n 文件状态= " + fileStatus +
	"\r\n 文件编码= " + fileCode );

	console.log("fileDownload    插件调用成功  ");
	mam.navigator.appfilemanage.fileDownload(fileDownloadCallback2,appCode,appServerCode,urlType,downLoadUrl,saveUrl,fileName,appName,fileSize,fileStatus,fileCode);
}
function fileDownloadCallback2(obj)
{	
	var fileprogress = obj.progress;	
	console.info("fileDownload  回调    "+ JSON.stringify(obj));
	console.log("fileDownload  fileprogress    "+ fileprogress);
}





