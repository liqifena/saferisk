{
	console.log('获取服务端文件信息 失败'+JSON.stringify(obj));
}
/**
	白名单 下载 【推荐】	 fileDownload2
	callback		回调
	appCode			应用编码		填写应用编码，保存文件至应用相对路径：
	appServerCode	应用服务编码	使用应用服务编码进行下载

	urlType			URL类型			0 白名单downLoadUrl必填
									1 应用服务编码	（此处填 1 	则appServerCode必填）
	param			请求参数		请求参数遵从 KEY:VALUE格式。			
	downLoadUrl		下载URL			文件下载URL  可为互联网URL 和 白名单URL
	saveUrl			本地保存url		保存应用相对路径 如：设置 /PDF   对应实际路径 SGCCINTSYS/PDF/1_pdf_101M_文档.pdf
	fileName		文件名称		保存本地文件名称 重命名文件 【文件名称必须带后缀】 1_doc_22b_文档.doc
	fileCode		文件编码		文件编码	内容自定义、唯一  用于批量删除
**/
// 2020-11-2 暂时注释
function fileDownloadA(id,filename)
{
	console.log('fileDownload2     filename= '+filename+'  id=  ' +id);
	if(id==1)
	{
		var appServerCode = 'download2';	//使用 服务编码 下载，此处填写 服务编码。
		var downLoadUrl = '';			
		var param={fileName:filename};		 
	}else
	{
		var appServerCode = '';
		var downLoadUrl = 'https://mam.zeus2.top:10030/sysCordova/controller/download/' + filename;//使用 白名单 下载，URL 后面直接配置参数
		var param= '';		
	}
	var urlType = id;					//0 白名单 1 应用服务编码	
	var saveUrl = '/serverfile';
	var fileName='local_'+filename;
	var fileCode = '1_server';

	console.log(
	" 应用编码= "+appCode+
	"\r\n 应用服务编码= "+ appServerCode +
	"\r\n 下载类型= "+ urlType +
	"\r\n 参数= "+ JSON.stringify(param) +
	"\r\n 下载URL= " + downLoadUrl+
	"\r\n 保存url= " + saveUrl +
	"\r\n 文件名称= " + fileName +
	"\r\n 文件编码= " + fileCode );
	mam.navigator.appfilemanage.fileDownload2(fileDownloadCallback,appCode,appServerCode,urlType,downLoadUrl,saveUrl,fileName,fileCode,param);
}

/**
	2020-10-30	fileDownload3	【2020-10-30  删除 urlType 字段		appServerCode 优先级最高   downLoadUrl 其次】


	白名单 下载 【推荐】	 fileDownload2
	callback		回调
	appCode			应用编码		填写应用编码，保存文件至应用相对路径：
	appServerCode	应用服务编码	使用应用服务编码进行下载

	【2020-10-30  删除 urlType 字段		appServerCode 优先级最高   downLoadUrl 其次】

	param			请求参数		请求参数遵从 KEY:VALUE格式。			
	downLoadUrl		下载URL			文件下载URL  可为互联网URL 和 白名单URL
	saveUrl			本地保存url		保存应用相对路径 如：设置 /PDF   对应实际路径 SGCCINTSYS/PDF/1_pdf_101M_文档.pdf
	fileName		文件名称		保存本地文件名称 重命名文件 【文件名称必须带后缀】 1_doc_22b_文档.doc
	fileCode		文件编码		文件编码	内容自定义、唯一  用于批量删除
**/

function fileDownload2(appServerCode,filename)
{
	console.log('fileDownload2     appServerCode= '+appServerCode+'  filename=  ' +filename);
	var param={fileName:filename};	
	var downLoadUrl = 'https://mam.zeus2.top:10030/sysCordova/controller/download/' + filename;//使用 白名单 下载，URL 后面直接配置参数
	var saveUrl = '/serverfile';
	var fileName='local_'+filename;
	var fileCode = '1_server';

	console.log(
	" fileDownload2 = "+
	" 应用编码= "+appCode+
	"\r\n 应用服务编码= "+ appServerCode +
	"\r\n 参数= "+ JSON.stringify(param) +
	"\r\n 下载URL= " + downLoadUrl+
	"\r\n 保存url= " + saveUrl +
	"\r\n 文件名称= " + fileName +
	"\r\n 文件编码= " + fileCode );
	mam.navigator.appfilemanage.fileDownload2(fileDownloadCallback,appCode,appServerCode,downLoadUrl,saveUrl,fileName,fileCode,param);
}


