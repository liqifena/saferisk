		mam.navigator.appfilemanage.appServerUpload(fileDownloadCallback,getFileListerrCallback,appCode,id,path,params)
		
	}else if(appCodeDIY!=""  && appServerCodeDIY!="")
	{
		alert('DIY应用编码 = '+appCodeDIY + '  DIY服务编码 = '+appServerCodeDIY);
		mam.navigator.appfilemanage.appServerUpload(fileDownloadCallback,getFileListerrCallback,appCodeDIY,appServerCode,path,params)
	}


	
	
