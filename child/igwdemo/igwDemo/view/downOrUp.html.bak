}

//获取本地文件URL
function getFileUrl(fileName)
 {	
	//console.log("getFileUrl   basefileInfo  " +  basefileInfo[2].fileUrl);
	//console.log("basefileInfo   filename  " +  basefileInfo[2].filename);
	console.log("getFileUrl	fileName  " + fileName);
	console.log("getFileUrl	basefileInfo  " + JSON.stringify(basefileInfo));

	if (basefileInfo !== null || basefileInfo !== undefined || basefileInfo !== '') {
		for(var i in basefileInfo){
				switch (fileName) {
					case basefileInfo[i].filename:
						console.log("getFileUrl:  "+basefileInfo[i].fileUrl);
						//basefileUrl = basefileInfo[i].fileUrl + "/" + fileName;
						//console.log("2 getFileUrl:  "+basefileUrl);
						return basefileInfo[i].fileUrl;
				}
