<input type='button' onclick="takePhotoNew()" value='拍照'/>&nbsp;&nbsp;&nbsp;&nbsp;
<input type='button' onclick="imageSelect()" value='照片多选'/>&nbsp;&nbsp;&nbsp;&nbsp;
<input type='button' onclick="cameraClick()" value='原生拍照'/>&nbsp;&nbsp;&nbsp;&nbsp;
<input type="file" multiple="" name="file[]" id="fileUrl" accept="*" onchange="onLoadFileInfo()">&nbsp;&nbsp;&nbsp;&nbsp;<br><br>

<textarea   rows="5" cols="40" id='sourceUrl' placeholder='资源路径  拍照或多选后，再上传。'></textarea><br><br>

<input type='button' onclick="appServerUpload('upload6')" value='单文件上传	【appServerUpload 推荐】'/>
&nbsp;&nbsp;&nbsp;&nbsp;<br><br>
<input type='button' onclick="fileUploads('upload8')" value='多文件上传	【fileUploads  2020-9 不可用 待修复】'/><br><br><br><br>

<span>****  图片预览   ****<span><br>
<img id='downloadImage' width="60%" height="80%"/><br><br>


<span>** ② 服务端  资源  展示 ***<span><br>
<input type='button' onclick="getFileListF()" value='服务端文件'/>&nbsp;&nbsp;&nbsp;&nbsp;
<input type='button' onclick="getFileInfo('SGCCINTSYS')" value='本地文件'/>&nbsp;&nbsp;&nbsp;&nbsp;
	<input type='button' onclick="removefiles('SGCCINTSYS',['1_server'])" value='批量删除本地文件'></input><br><br>


<div id="showFile"></div><br><br>






<span>** ⑨ 自定义 文件下载***<span><br><br>
<input type='button' onclick="executeGoToScanPager()"  value='资源生成二维码 快速扫码填入信息'></input>&nbsp;&nbsp;&nbsp;&nbsp;<br><br>
<textarea   rows="5" cols="40" id='diyUrl' placeholder='输入文件URL'></textarea><br><br>
<input type='texinput' size="30"  id='diyName' placeholder='输入文件名称 【必填 带后缀】'></input><br><br>

<input type='button' onclick="diyDownload()"  value='下载'></input>&nbsp;&nbsp;&nbsp;&nbsp;
<input type='button' onclick="diypauseDown()" value='暂停'></input><br><br>

<input type='button' onclick="diybd()" value='本地打开'></input>&nbsp;&nbsp;&nbsp;&nbsp;
<input type='button' onclick="diyzx()" value='在线打开doc '></input><br><br>
<input type='button' onclick="removefiles('SGCCINTSYS',['1_diyFile'])" value='删除'></input><br><br>

<span>** ⑥ aac 文件上传   ************<span><br><br>
<input type='button' onclick="startRecordAudio()"  value='开始 aac 音频录制'></input>&nbsp;&nbsp;&nbsp;&nbsp;
<input type='button' onclick="finishRecordAudio()" value='结束 aac 音频录制'></input><br><br>
播放AAC :<audio  id="aacAudio"  width="350" height="100%" type="video/mp4" src=""  controls="controls"></audio><br><br>
文件路径:<input id="fileAACUrl" name="fileAAC" type="text" class="bk"  size="30" readonly="true"><br><br>
<input type='button' onclick="uploadAAC()" value='上传	【appServerUpload 推荐】'/><br><br>




<span>** ⑦ 原生文件系统 2020-7-31   ************<span><br><br>
		
<input accept='file/*' type='file'>文件系统</input><br><br>

<input id="fileId1" type="file" accept="image/png,image/gif" name="file" >文件系统 222</input><br><br>
<input id="fileId2" type="file" accept="application/msword" name="file" >文件系统   文档</input><br><br>

<input class="js_upFile cover1" type="file" name="cover" accept="image/*" capture="camera" multiple>兼容 IOS的写法</input>

<br><br>


<span>** ⑧ 老下载 不推荐   ************<span><br><br>

<input type='button' onclick="fileDownloadOld()"  value='down 下载'></input>&nbsp;&nbsp;&nbsp;&nbsp;

