	}
 }

//判断文件状态
function getFileStatus(fileName)
 {	
	fileName = 'local_'+fileName;
	if (basefileInfo !== null || basefileInfo !== undefined || basefileInfo !== '') {
		for(var i in basefileInfo){

				//console.info(i+'	服务端文件  '+ fileName);
				//console.info(i+'	本地文件  '+basefileInfo[i].filename);
				//console.info(i+"	getFileStatus:		"+(fileName == basefileInfo[i].filename && basefileInfo[i].fileStatus == '3'));

				if(fileName == basefileInfo[i].filename && basefileInfo[i].fileStatus == '3')
				{
					console.info(i+"	文件存在:		"+basefileInfo[i].filename);
					return true;
					break;
				}else
				{
					console.info(i+"	文件不存在:		"+basefileInfo[i].filename);
				}
		}
	 }
}

/**
	获取上传服务端文件信息
	传入应用编码：appCode: SGCCINTSYS 
**/
function getFileListF()
{
	console.log('获取服务端文件信息');
	mam.navigator.ajax.getJSON('SGCCINTSYS','',getFileList, getFileListCallback, getFileListerrCallback);
}
function getFileListCallback(obj)
{
	var serviceFile = obj.data;
	var aurl = '';
	$("#showFile").empty();

	for(var i in serviceFile){

		var serviceFileName = serviceFile[i].fileName;
		var serviceFileSize = serviceFile[i].fileSize;

		//取出文件的扩展名
		 var index = serviceFileName.lastIndexOf(".");
		 var ext = serviceFileName.substr(index+1);


		if(getFileStatus(serviceFileName))
		{
			if(ext == 'zip')
			{
				aurl +='<input type=\'button\' onclick=\"decompression(\'local_'+serviceFileName+'\')\" value=\''+serviceFileName+' 【解压 zip】\'/><br><br>';
				//aurl +='<input type=\'button\' onclick=\"removefile(\'SGCCINTSYS\',\'local_'+serviceFileName+'\')\" value=\''+serviceFileName+' 【删除 zip】\'/><br><br>';

			}else if(ext == 'png' ||ext == 'jpg'  )
			{
				aurl +='<input type=\'button\' onclick=\"preview(\'local_'+serviceFileName+'\')\" value=\''+serviceFileName+' 【预览本地图片】\'/><br><br>';

				//aurl +='<input type=\'button\' onclick=\"removefile(\'SGCCINTSYS\',\'local_'+serviceFileName+'\')\" value=\''+serviceFileName+' 【删除】\'/><br><br>';
			}else if(ext == 'doc' ||ext == 'docx'  ||ext == 'pdf')
			{
				aurl +='<input type=\'button\' onclick=\"openFile(\'local_'+serviceFileName+'\')\" value=\''+serviceFileName+' 【本地打开】\'/>&nbsp;&nbsp;&nbsp;&nbsp;';
				aurl +='<input type=\'button\' onclick=\"openFile(\'https://mam.zeus2.top:10030/sysCordova/controller/download2?fileName='+serviceFileName+'&inline=true\')\" value=\''+serviceFileName+' 【在线打开】\'/><br><br>';
				aurl +='<input type=\'button\' onclick=\"removefile(\'SGCCINTSYS\',\'local_'+serviceFileName+'\')\" value=\''+serviceFileName+' 【删除本地】\'/><br><br>';
			}else if(ext == 'aac' ||ext == 'mp3'  ||ext == 'mp4')
			{
				aurl +='<input type=\'button\' onclick=\"finishonSuccess(\'local_'+serviceFileName+'\')\" value=\''+serviceFileName+' 【播放aac】\'/><br><br>';

			}
		}else
		{
			aurl +='<input type=\'button\' onclick=\"fileDownload2(\'download2\',\''+serviceFileName+'\')\" value=\''+serviceFileName+' 【fileDownload2 白名单下载】\'/><br>';
			aurl +='<input type=\'button\' onclick=\"fileDownload2(\' \',\''+serviceFileName+'\')\" value=\''+serviceFileName+' 【fileDownload2 服务编码下载  推荐】\'/><br><br>';

			//aurl +='<input type=\'button\' onclick=\"fileDownload3(\'download2\',\''+serviceFileName+'\')\" value=\''+serviceFileName+' 【fileDownload3 白名单下载】\'/><br>';
			//aurl +='<input type=\'button\' onclick=\"fileDownload3(\' \',\''+serviceFileName+'\')\" value=\''+serviceFileName+' 【fileDownload3 服务编码下载  推荐】\'/><br><br>';
		}
	}
	
		console.info('获取服务端文件信息 成功 aurl   '+aurl);
		$("#showFile").html(aurl);

}
