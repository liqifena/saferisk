/**

	cordova环境准备  加载完毕

**/
function onDeviceReady() {
	deviceReady = true;
	console.log("cordova加载完毕！");
	getFileInfo('SGCCINTSYS');// 获取本地文件信息
	getFileListF();//获取服务端文件信息

	
}

