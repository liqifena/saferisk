//*********************************************************
// 截取字符串
function getCaption(obj){

	//var index=obj.lastIndexOf("\."); 获得 . 之后
	//obj=obj.substring(index,obj.length);


	var index=obj.lastIndexOf("\/"); //获得 / 之前
	obj=obj.substring(0,index);
	// console.log(obj);
	return obj;
}
// 截取字符串
function getCaption2(obj){
	console.log(obj.data.imageList);
	var imageList = (obj.data.imageList).replace(/\[|]/g,'');
	var imageArrayList = imageList.split(",");
	var resultString=""; 
	for(var i = 0; i < imageArrayList.length;i++){ 
		resultString+=imageArrayList[i]; 
	} 
	return resultString;
}











