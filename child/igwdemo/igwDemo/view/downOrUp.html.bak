function initInput () {

   var nav = navigator.userAgent.toLowerCase();
    var isIos = (nav.indexOf('iphone') != -1) || (nav.indexOf('ipad') != -1);
   if (isIos) {
       $("input:file").removeAttr("capture");
      };
   }


//system 判断
function phoneType () {
    var u = navigator.userAgent;
    var isiOS = !!u.match(/\(i[^;]+;( U;)? CPU.+Mac OS X/);
    var isAndroid = u.indexOf('Android') > -1 || u.indexOf('Adr') > -1; //android终端
    if(isAndroid){
        return 'android'
    }else if(isiOS){
        return 'ios'
    }else{
		return 'gg'
	}
}

/**

	【 作废 作废 作废】
**/
		
function openFileManage()
{
	if(!deviceReady){
			//执行到这边表示cordova环境没有准备好
			console.log('执行到这边表示cordova环境没有准备好');
			return;
		}
	console.log('openFileManage');
	try{	
	navigator.appfilemanage.open();
	}catch(ex)
	{
		console.log("try: "+ex.message);
	}	
}
/**
	获取文件信息
	传入应用编码：appCode: ‘SYS’
 
**/
function getFileInfo(obj)
{
	console.log('获取文件信息'+ obj);
	mam.navigator.appfilemanage.getFileInfo3(getFileInfoCallback,obj);
}
/**
	回调说明：
	fileStatus		文件状态 对应的值域为{1，-1，0，3，4}。
					 1：提交下载成功；
					 0：等待用户确认（在蜂窝网络下需要用户确认）；
					 -1：提交下载失败（用户确认时取消，或者网络异常，或者本地存储状态异常）；
					 3：下载成功；
					 4：下载暂停。

	fileUrl			本地文件路径【文件路径为i国网指定路径】
	filename	    文件名称
	fileSize		文件大小
	fileCode		文件编码

**/
var basefileInfo="";
function getFileInfoCallback(obj)
{
	console.log('getFileInfo3 Callback  ' + JSON.stringify(obj));
	basefileInfo = obj;
}




/**
	文件 下载 
	appCode			应用编码		填写应用编码，保存文件至应用相对路径：
----appServerCode	应用服务编码	固定值  20200618 目前先不填----

	urlType			URL类型		20200618 目前先填 0 使用白名单下载
								0 白名单downLoadUrl必填
								1 应用服务编码	（此处填 1 	则appServerCode必填）

	downLoadUrl		下载URL			文件下载URL  可谓互联网URL 和 白名单URL
	saveUrl			本地保存url		保存应用相对路径 如：设置 /PDF   对应实际路径 SGCCINTSYS/PDF/1_pdf_101M_文档.pdf
	fileName		文件名称		保存本地文件名称 重命名文件
	appName			应用名称		应用名称		
----fileSize		文件大小		固定值 作废 传10000----
----fileStatus		文件状态		固定值 作废 传 0 文件状态：0 允许打开  1 不允许打开----
	fileCode		文件编码		文件编码	内容自定义、唯一  用于批量删除

function mediaDownload(id,codova)
{
	var appCode ='SYSCordova'+codova;
	var appServerCode ='download';
	var urlType  =0;
	var downLoadUrl  ='https://mam.zeus2.top:10030/html8/'+id+'.mp4';
	var saveUrl  ='/SYSCordova_media'+codova;
	var fileName   ='测试MP4_'+id+".mp4";
	var appName   ='实验室Cordova_'+codova;
	var fileSize   ='2169451';
	var fileStatus  ='0';
	var fileCode  ='SYSCordova_media_'+id;

	console.log(
	" 应用编码= "+appCode+
	"\r\n 应用服务编码= "+ appServerCode +
	"\r\n 下载类型= "+ urlType +
	"\r\n 下载URL= " + downLoadUrl+
	"\r\n 保存url= " + saveUrl +
	"\r\n 文件名称= " + fileName +
	"\r\n 应用名称= " + appName +
	"\r\n 文件大小= " + fileSize +
	"\r\n 文件状态= " + fileStatus +
	"\r\n 文件编码= " + fileCode );

	console.log("mediaDownload    插件调用成功  "+id);
	mam.navigator.appfilemanage.fileDownload(mediaDownloadCallback,appCode,appServerCode,urlType,downLoadUrl,saveUrl,fileName,appName,fileSize,fileStatus,fileCode);
}

function mediaDownloadCallback(obj)
{
	console.log("mediaDownload    插件调用  回调"+ JSON.stringify(obj));
}
**/

/**
	mp4下载 回调 

	fileStatus对应的值域为{1，-1，0，3，4}。
			1：提交下载成功；
			0：等待用户确认（在蜂窝网络下需要用户确认）；
			-1：提交下载失败（用户确认时取消，或者网络异常，或者本地存储状态异常）；
			3：下载成功；
			4：下载暂停。
			progress对应的值域为-1至100的整型数。
			-1：下载失败；其它则为下载进度状态值。

**/



/**
	删除文件
**/
function removefile(appcode,filename)
{
	console.log("应用编码 "+appcode+"\r\n 文件名称 "+filename);
	mam.navigator.appfilemanage.rmFile(rmcallback,appcode,filename);

}
/**
	批量 删除文件 
	appcode				应用编码
	fileCode			文件编码 内容自定义、唯一 用于删除操作 数据类型 数组 ['fileCodes1','fileCodes2']
**/
function removefiles(appcode,fileCodes)
{
	console.log(" 应用编码 "+appcode+"\r\n 文件  "+fileCodes);
	mam.navigator.appfilemanage.rmFiles(rmcallback,appcode,fileCodes);
}
/**
	删除 回调
**/
function rmcallback(obj)
{
	console.log(JSON.stringify(obj));
	// 将基础信息情况，否则文件删除后有缓存
	basefileInfo='';
	onDeviceReady();
}





