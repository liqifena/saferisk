function preview(fileName)
{
	var fileUrl =  getFileUrl(fileName);
	console.log("preview  fileUrl:  "+fileUrl);	

	if(phoneType()=='ios'){
		//IOS 文件完整路径   igwsgcc300/serverfile/local_1597368143580045.jpg
		//IOS 存放与应用包同级目录  应用自定义文件夹。
		document.getElementById("downloadImage").src = '../../'+fileUrl;
	}else if(phoneType()=='android'){
		// 安卓 与应用版本同级
	
		document.getElementById("downloadImage").src = '../../../../'+fileUrl;

	}
	// 将基础信息清空，否则文件删除后有缓存
	//basefileInfo='';	
}



