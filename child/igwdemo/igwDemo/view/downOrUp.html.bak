/**
	打开文件
	filePath	文件路径   
			本地打开：  文件下载后自定义路径【见 downloadDOC  saveUrl 】	 DOC/1_doc_22b_文档.doc
			在线打开：	https://mam.zeus2.top:10030/html8/1_doc_22b_文档.doc
**/
	// URL 测试
	var URLRexExp = new RegExp(/^[A-Za-z]+:\/\/[A-Za-z0-9-_]+.[A-Za-z0-9-_%&\?\/.:=]+$/);


	function openFile(fileInfo)
 {
	 var cpUrl = getCaption(fileInfo);
	console.log("截取url:  "+cpUrl);
	if(URLRexExp.test(cpUrl))
	{
		console.log("在线打开 " +fileInfo);
		
		//mam.navigator.appfilemanage.openFile2(succCallback,errorcallback, fileInfo);
		mam.navigator.appfilemanage.openFile(succCallback,errorcallback, fileInfo);
	}else{		
		var fileUrl =  getFileUrl(fileInfo);
		console.log("本地打开 fileUrl:  "+fileUrl);
		//mam.navigator.appfilemanage.openFile2(succCallback,errorcallback,fileUrl);
		mam.navigator.appfilemanage.openFile(succCallback,errorcallback,fileUrl);
	}
 }


 function succCallback(v)
{
	 basefileUrl="";
	console.log("openFile 成功  " + JSON.stringify(v));
}
