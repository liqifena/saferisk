  </tr>
  <tr>
    <td>&nbsp;</td>
  </tr>
  <tr>
    <td><table width="90%" border="0" align="center" cellpadding="0" cellspacing="0">
      <tr>
        <td height="30">
        </td>
      </tr>
    </table></td>
  </tr>
  <tr>
    <td>
	<table width="90%" border="0" align="center" cellpadding="0" cellspacing="0" class="bk">
      <tr>
        <td height="30" align="left" >
        	<span id="imgUrlA" class="STYLE6">图片路径存放此处..</span>

        </td>
      </tr>
    </table></td>
  </tr>
  <tr>
    <td>&nbsp;</td>
  </tr>
</table>
<br />
<table width="98%" border="0" align="center" cellpadding="0" cellspacing="0">
  <tr>
   <td height="30" align="right">
    	<table width="120" border="0" cellspacing="0" cellpadding="0" onclick="upload()" bgcolor="#0A7E81">
      		<tr>
        		<td height="46" align="center" >
        			<span class="STYLE7">appserverupload 上传</span>
        		</td>
      		</tr>
    	</table>      
    </td>

	  <td height="30" align="right">
    	<table width="120" border="0" cellspacing="0" cellpadding="0" onclick="ajaxUpload()" bgcolor="#0A7E81">
      		<tr>
        		<td height="46" align="center" >
        			<span class="STYLE7">ajax 上传</span>
        		</td>
      		</tr>
    	</table>      
    </td>


    <td height="30" align="right">
    	<table width="120" border="0" cellspacing="0" cellpadding="0" onclick="clearData()" bgcolor="#0A7E81">
      		<tr>
        		<td height="46" align="center" >
        			<span class="STYLE7">清除</span>
        		</td>
      		</tr>
    	</table>      
    </td>

	 
  </tr>
  <tr>
  <td height="30" align="right">
    	<table width="120" border="0" cellspacing="0" cellpadding="0" onclick="distinguish()" bgcolor="#0A7E81">
      		<tr>
        		<td height="46" align="center" >
        			<span class="STYLE7">识图</span>
        		</td>
      		</tr>
    	</table>      
    </td>
  </tr>
</table>
<br><span>*********  H5 选择资源   ************<span>	
<br />
选相册和相机照片：<br/>
	<input type="file" id='albumImage' accept="image/*"  onchange="onLoadImg()"><br/>
	选相机照片：<br/>
	<input type="file" id='cameraImage' accept="image/*" capture="camera" onchange="onLoadImg()"><br/>
	录像：<br/>
	<input type="file" accept="video/*" capture="camcorder"><br/>
	录音：<br/>
	<input type="file" accept="audio/aac" capture="microphone"><br/>

<div id="showImage"></div>
<br />
<span>*********  长按 识图   ************<span><br>	

<table width="98%" border="0" align="center" cellpadding="0" cellspacing="0">
  <tr>
    <td bgcolor="#0A7E81"><table width="100%" border="0" cellpadding="0" cellspacing="0">
      <tr>
        <td width="31%" height="60" align="right"><img ID = 'touchArea' src="https://mam.sgcc.com.cn/html/internal/qrimage.jpg" width="100" height="100" /></td>
        <td width="69%">
        	<span class="STYLE1">长按图片，识别图中二维码</span>
        </td>
      </tr>
    </table></td>
  </tr>
</table>
<br />



</body>
</html>
