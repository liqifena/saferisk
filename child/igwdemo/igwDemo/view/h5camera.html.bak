<!DOCTYPE html>
<html>
<head>
	<meta name="viewport"	content="width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no" />
	<meta name="format-detection" content="telephone=no" />
	<meta name="apple-mobile-web-app-capable" content="yes" />
	<meta name="apple-mobile-web-app-status-bar-style" content="black" />
	<meta http-equiv="Content-Type" content="text/html;charset=UTF-8" />
</head>
	<script type="text/javascript" charset="utf-8" src="../cordova.js"></script>
	<script src="../js/vconsole.min.js"></script>
	<script type="text/javascript">
	var vConsole = new VConsole();


        var img = document.getElementById('show-img');
        var input = document.getElementById('input');
        input.addEventListener('change', function (e) {
            alert('触发change事件');
            console.log('change', e);
            var file = e.target.files[0];
            e.target.value = '';
            var uri = URL.createObjectURL(file);
            img.src=uri;
        });
        input.addEventListener('input', function(e) {
            alert('触发input事件');
            console.log('input', e);
        });
    </script>


<body>
a标签测试
	<a class="link external" href="http://www.kaiyuancn.com/Cn/Index/listView/catid/20.html" style="width:500px;height:50px;background:red;display:blck;">cccc</a><br/><br/>
<a class="link external" href="http://www.kaiyuancn.com/Public/Uploads/uploadfile/files/20180928/20180928170508_5badeec455d4d.xls"  
				download="客户联系单.xls" 
				style="width:50px;height:50px;background:red">hello</a><br/><br/>

	选相册和相机照片：<br/>
	<input type="file" accept="image/*" id="input"><br/>
	选相机照片：<br/>
	<input type="file" accept="image/*" capture="camera" id="input"><br/>
	录像：<br/>
	<input type="file" accept="video/*" capture="camcorder" id="input"><br/>
	录音：<br/>
	<input type="file" accept="audio/*" capture="microphone" id="input"><br/>


	参考：https://blog.csdn.net/rui_code/article/details/84584521




	   <div>
        <img id="show-img" src="">
        <input type="file" accept="image/*" capture="camera" id="input" value="点击打开相机">
    </div>


</body>