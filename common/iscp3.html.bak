<!DOCTYPE html>
<html>

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1,minimum-scale=1,maximum-scale=1,user-scalable=no" />
  <title></title>
  <!--标准mui.css-->
  <link rel="stylesheet" href="../css/mui.min.css">
  <!--App自定义的css-->
  <link rel="stylesheet" type="text/css" href="../css/app.css" />
  <!--<link rel="stylesheet" type="text/css" href="../css/mui.picker.min.css" />-->
  <style>
    .mui-btn {
      font-size: 16px;
      padding: 8px;
      margin: 3px;
    }

    h5.mui-content-padded {
      margin-left: 3px;
      margin-top: 20px !important;
    }

    h5.mui-content-padded:first-child {
      margin-top: 12px !important;
    }

    .ui-alert {
      text-align: center;
      padding: 20px 10px;
      font-size: 16px;
    }
  </style>
</head>

<body>
  <header class="mui-bar mui-bar-nav">
    <a class="mui-action-back mui-icon mui-icon-left-nav mui-pull-left"></a>
    <h1 class="mui-title">iscp（安全交互平台）</h1>
  </header>
  <div class="mui-content">
    <div class="mui-content-padded">
      <h5 class="mui-content-padded">示例</h5>
      <h5 class="mui-content-padded">链路唯一标识(ip):<span id="ISCP_IP"></span></h5>
      <h5 class="mui-content-padded">链路唯一标识(port)):<span id="ISCP_PORT"></span></h5>
      <h5 class="mui-content-padded">用户id:<span id="ISCP_USER"></span></h5>
      <h5 class="mui-content-padded">appid:<span id="ISCP_APPID"></span></h5>
      <h5 class="mui-content-padded">互联网大区(ip):<span id="XTBG_IP"></span></h5>
      <h5 class="mui-content-padded">互联网大区(port):<span id="XTBG_PORT"></span></h5>
      <br />
      <button id='initIscp' class="mui-btn mui-btn-block" type='button'>建立连接</button>
      <h5 class="mui-content-padded">日志:<br /><span id="iscp"></span></h5>

      <button class="mui-btn mui-btn-block" type='button' onclick="test()">测试应用服务器</button>
      <h5 class="mui-content-padded">结果:<br />
        <pre id="testResult"></pre>
      </h5>

	   <button class="mui-btn mui-btn-block" type='button' onclick="test2()">测试应用服务器22</button>
      <h5 class="mui-content-padded">结果:<br />

	  <button class="mui-btn mui-btn-block" type='button' onclick="test3()">测试应用服务器333</button>
      <h5 class="mui-content-padded">结果:<br />
         
      </h5>

    </div>
  </div>
  <script src="../js/mui.min.js"></script>
  <script src="../js/jquery-3.6.0.min.js"></script>
  <script src="../wx/uap.js"></script>
  <script src="iscp3.js"></script>
  <script>
    uap.ready(function () {
      //页面加载完的直接调用的方法
      mui('#ISCP_IP')[0].innerHTML = UAPCFG.ISCP_IP;
      mui('#ISCP_PORT')[0].innerHTML = UAPCFG.ISCP_PORT;
      mui('#ISCP_USER')[0].innerHTML = UAPCFG.ISCP_USER;
      mui('#ISCP_APPID')[0].innerHTML = UAPCFG.ISCP_APPID;
      mui('#XTBG_IP')[0].innerHTML = UAPCFG.XTBG_IP;
      mui('#XTBG_PORT')[0].innerHTML = UAPCFG.XTBG_PORT;

    })


    mui('.mui-content').on('click', '#initIscp', function () {

      ISCP_Load(function () {

      });

    })


function test() {
		console.log('11111');

		$.ajax({
			type:"post",
			url: contextPath +"/api/home/part/service/get?terminal=app",
			contentType: "application/json",
			success:function(data){
				requestOk(data,'',function(){
					console.log(data);
				},customCodeError);
			},
			error:function(status){
				console.log(status);
			}
		}); 
      
    }

function test2() {

		$.post( contextPath +"/api/home/part/service/get?terminal=app", 
		 
		function (data, status, xhr) {
                console.log("ajax result", data, status);
             })
 }

 function test3() {

		$.get( contextPath +"/", 
		 
		function (data, status, xhr) {
                console.log("ajax result", data, status);
             })
 }
	
  </script>
</body>

</html>